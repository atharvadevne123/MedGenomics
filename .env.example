# Copy this file to .env and fill in your values.
# Never commit .env to version control.

POSTGRES_DB=medgenomics
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Secret key for HMAC token signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Database URL (defaults to local SQLite if unset)
DATABASE_URL=postgresql://admin:changeme@localhost:5432/medgenomics
